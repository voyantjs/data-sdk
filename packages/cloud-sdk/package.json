{
  "name": "@voyantjs/cloud-sdk",
  "version": "0.7.0",
  "description": "Public TypeScript SDK for Voyant Cloud APIs.",
  "license": "FSL-1.1-Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/voyantjs/cloud-sdk.git",
    "directory": "packages/cloud-sdk"
  },
  "homepage": "https://github.com/voyantjs/cloud-sdk#readme",
  "bugs": {
    "url": "https://github.com/voyantjs/cloud-sdk/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "sideEffects": false,
  "keywords": [
    "voyant",
    "voyant-cloud",
    "sdk",
    "typescript"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "bundleDependencies": [
    "@voyant-sdk/sdk-core"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src --max-warnings 0",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@voyant-sdk/sdk-core": "workspace:*"
  },
  "peerDependencies": {
    "typesense": ">=2.0.0 <4.0.0"
  },
  "peerDependenciesMeta": {
    "typesense": {
      "optional": true
    }
  },
  "devDependencies": {
    "@voyant-sdk/eslint-config": "workspace:*",
    "@voyant-sdk/typescript-config": "workspace:*",
    "eslint": "^9.39.1",
    "typescript": "5.9.2",
    "typesense": "^3.0.6"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  }
}
